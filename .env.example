# ============================================================================
# FAB Project — Environment Variables
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit `.env.local`. All accounts/keys are owned by the customer.
# ============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used for Stripe redirects, password-reset links).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Product name shown in the UI (customer decision — see CUSTOMER DECISIONS).
NEXT_PUBLIC_APP_NAME=Lesson Pack Generator
# Support email shown on legal/help pages (customer decision).
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# --- Supabase (database + auth) ----------------------------------------------
# From: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses Row Level Security — used only in server code (AI
# generation, webhooks, admin). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (AI generation) -----------------------------------------------
# From: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# Model used for generation. Default balances quality/cost; switch to
# claude-opus-4-8 for higher quality at higher cost (see README cost note).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Stripe (subscriptions) --------------------------------------------------
# From: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Created when you set up the Stripe webhook endpoint (see README).
STRIPE_WEBHOOK_SECRET=
# The recurring Price ID for the teacher subscription plan.
STRIPE_PRICE_ID=

# --- Business rules (defaults; can be overridden in the admin settings) -------
# Number of free lesson packs before the paywall (customer decision).
FREE_TRIAL_PACK_LIMIT=3
# Default exam board for the MVP (customer decision — currently Edexcel).
NEXT_PUBLIC_DEFAULT_EXAM_BOARD=Edexcel
